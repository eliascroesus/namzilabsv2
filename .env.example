# --- Database (Neon Postgres) ---
# Pooled connection string from Neon. Used by the app at runtime and by migrations.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Encryption ---
# 32-byte key for AES-256-GCM encryption of stored OAuth tokens / API keys / signing secrets.
# Generate: `openssl rand -base64 32`  (base64) or `openssl rand -hex 32` (hex)
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_OR_HEX_KEY"

# --- Inngest (durable execution / queue / cron) ---
# From the Inngest dashboard. Not required for local `inngest-cli dev`.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- WorkOS AuthKit (auth + organizations) ---
# From the WorkOS dashboard (https://dashboard.workos.com).
WORKOS_API_KEY="sk_test_..."
WORKOS_CLIENT_ID="client_..."
# Session cookie password, 32+ characters. Generate: `openssl rand -base64 24`
WORKOS_COOKIE_PASSWORD="REPLACE_WITH_32_PLUS_CHAR_SECRET"
# Must exactly match a redirect URI configured in the WorkOS dashboard.
NEXT_PUBLIC_WORKOS_REDIRECT_URI="http://localhost:3000/callback"

# --- App ---
# Public base URL of this deployment. Used for post-sign-out redirect and when
# registering webhooks with providers.
APP_BASE_URL="https://app.namzilabs.com"
