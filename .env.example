# --- Database (Neon Postgres) ---
# Pooled connection string from Neon. Used by the app at runtime and by migrations.
DATABASE_URL="postgresql://user:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# --- Encryption ---
# 32-byte key for AES-256-GCM encryption of stored OAuth tokens / API keys / signing secrets.
# Generate: `openssl rand -base64 32`  (base64) or `openssl rand -hex 32` (hex)
ENCRYPTION_KEY="REPLACE_WITH_32_BYTE_BASE64_OR_HEX_KEY"

# --- Inngest (durable execution / queue / cron) ---
# From the Inngest dashboard. Not required for local `inngest-cli dev`.
INNGEST_EVENT_KEY=""
INNGEST_SIGNING_KEY=""

# --- Clerk (auth + organizations). Optional in local dev; when unset, auth is bypassed. ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# --- Internal ---
# Shared secret protecting the /api/replay endpoint. If unset, replay is open (dev only).
INTERNAL_API_SECRET=""

# Public base URL of this deployment (used when registering webhooks with providers).
APP_BASE_URL="https://app.namzilabs.co"
